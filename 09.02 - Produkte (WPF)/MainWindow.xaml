<Window x:Class="_09._02___Produkte__WPF_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_09._02___Produkte__WPF_"
        mc:Ignorable="d"
        Title="Produktinfomrationen" Width="360" Height="280" ResizeMode="NoResize">
    <Grid>
        <Label Content="Kategorien:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="25" Width="150" Grid.ColumnSpan="2" VerticalContentAlignment="Center"/>
        <Label Content="Produktname:" HorizontalAlignment="Left" Margin="180,10,0,0" VerticalAlignment="Top" Height="25" Width="150" Grid.Column="1" Grid.ColumnSpan="2" VerticalContentAlignment="Center"/>

        <ComboBox x:Name="comboBoxKategorie" HorizontalAlignment="Left" Margin="10,40,0,0" VerticalAlignment="Top" Width="150" Height="25" SelectionChanged="KategorieWahl" Grid.ColumnSpan="2" VerticalContentAlignment="Center"/>
        <TextBox x:Name="textBoxProduktname" HorizontalAlignment="Left" Margin="180,40,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Height="25" Grid.Column="1" Grid.ColumnSpan="2" IsReadOnly="True" IsUndoEnabled="False" VerticalContentAlignment="Center"/>

        <Label Content="Produkte:" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top" Width="150" Height="25" Grid.ColumnSpan="2" VerticalContentAlignment="Center"/>
        <Label Content="Preis:" HorizontalAlignment="Left" Margin="180,100,0,0" VerticalAlignment="Top" Width="150" Grid.Column="1" Grid.ColumnSpan="2" VerticalContentAlignment="Center"/>

        <ListBox x:Name="listBoxProdukte" Margin="10,130,0,0" Width="150" Height="100" HorizontalAlignment="Left" VerticalAlignment="Top" SelectionChanged="Produktwahl" Grid.ColumnSpan="2"/>
        <TextBox x:Name="textBoxPreis" HorizontalAlignment="Left" Margin="180,130,0,0" VerticalAlignment="Top" Width="150" Height="25" TextChanged="TextBox_TextChanged" Grid.Column="1" Grid.ColumnSpan="2" IsReadOnly="True" IsUndoEnabled="False" TextWrapping="Wrap" VerticalContentAlignment="Center"/>
        <Button Content="JSON neu lesen" HorizontalAlignment="Left" Margin="244,210,0,0" VerticalAlignment="Top" Click="Reload"/>
    </Grid>
</Window>
